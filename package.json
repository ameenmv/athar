{
  "name": "athar-mcp",
  "version": "0.2.0",
  "description": "أثر — AI-powered programming lesson memory with spaced repetition. An MCP server that captures lessons from coding sessions and helps you never repeat the same mistake.",
  "type": "module",
  "bin": {
    "athar": "./dist/cli/index.js",
    "athar-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "dashboard/.output"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:cli": "tsx src/cli/index.ts",
    "test": "node --test",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "spaced-repetition",
    "learning",
    "programming-lessons",
    "ai-assistant",
    "antigravity",
    "cli",
    "sqlite",
    "local-first"
  ],
  "author": "Ameen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ameenmv/athar.git"
  },
  "homepage": "https://github.com/ameenmv/athar#readme",
  "bugs": {
    "url": "https://github.com/ameenmv/athar/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "inquirer": "^12.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

